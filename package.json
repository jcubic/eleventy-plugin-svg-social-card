{
  "name": "eleventy-plugin-svg-social-card",
  "version": "0.1.0",
  "description": "Eleventy plugin that generates per-page social card images (OG image / Twitter card) from an SVG template using a headless browser.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "example:single":   "cd examples/single   && npx eleventy --config=.eleventy.js",
    "example:multiple": "cd examples/multiple && npx eleventy --config=.eleventy.js"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0"
  },
  "keywords": [
    "eleventy",
    "eleventy-plugin",
    "social-card",
    "open-graph",
    "og-image",
    "twitter-card",
    "svg"
  ],
  "author": "Jakub T. Jankiewicz <jcubic@jcubic.pl> (https://jakub.jankiewicz.org)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcubic/eleventy-plugin-svg-social-card.git"
  },
  "bugs": {
    "url": "https://github.com/jcubic/eleventy-plugin-svg-social-card/issues"
  },
  "homepage": "https://github.com/jcubic/eleventy-plugin-svg-social-card#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "liquidjs": "^10.0.0",
    "puppeteer": "^23.0.0",
    "xmllint-wasm": "^5.2.0"
  },
  "peerDependencies": {
    "@11ty/eleventy": ">=2.0.0"
  }
}
